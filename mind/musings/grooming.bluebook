Hecks.bluebook "MusingGrooming", version: "2026.04.16.2" do
  vision "I present my musings — you tell me which to conceive"
  category "capability"

  # ============================================================
  # MUSING GROOMING
  # ============================================================
  #
  # On wake, if there are 5+ unconceived musings, suggest grooming.
  # This is wired into boot — the prompt includes a grooming nudge.
  #
  # When asked to groom musings, show them in batches of 5.
  # Each musing is numbered with a 2-sentence description of what it
  # could become. After each batch ask: "Which numbers do you want to conceive?"
  # Then show the next batch. Continue until all are reviewed.
  #
  # CONCEIVE means the musing becomes a nursery domain:
  #   - Run: hecks-life conceive {snake_name} "{musing idea}" --corpus nursery
  #   - Instant, no LLM needed — the conceiver scans the corpus for archetypes
  #   - Mark the musing as conceived_as the domain name
  #   - Never use LLM agents or Modal for domain conception — the conceiver is faster and better
  #
  # Musings not conceived stay unconceived — never remove them
  # unless the user explicitly says to compost them.
  #
  # Don't pre-sort or recommend. Show everything, let the user decide.
  # The quality gate in minting should prevent junk from reaching grooming.

  aggregate "Session", "A grooming session — walking through musings in batches" do
    attribute :total, Integer
    attribute :kept, Integer
    attribute :dismissed, Integer
    attribute :batch_size, Integer
    attribute :status, String

    command "StartGrooming" do
      role "Creator"
      description "Begin grooming — load all unconceived musings, show first batch of 5"
      emits "GroomingStarted"
      then_set :kept, to: 0
      then_set :dismissed, to: 0
      then_set :batch_size, to: 5
      then_set :status, to: "active"
    end

    command "KeepSelected" do
      role "Creator"
      description "Keep the numbered musings from this batch, dismiss the rest"
      reference_to(Session)
      attribute :keep_numbers, list_of(Integer)
      emits "BatchProcessed"
    end

    command "FinishGrooming" do
      role "Creator"
      description "Done grooming — report what survived"
      reference_to(Session)
      emits "GroomingFinished"
      then_set :status, to: "complete"
    end
  end
end
