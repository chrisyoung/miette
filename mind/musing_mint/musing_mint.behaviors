Hecks.behaviors "MusingMint" do
  vision "Behavioral tests for the MusingMint capability — exercises the mint pipeline in memory, including the skip and persist branches"

  # ── Mint aggregate ──────────────────────────────────────────

  # Every test passes name: "test" so the runtime resolves to a single
  # fresh Mint record (independent of the fixture pool seeded for the
  # canned-response adapter) ; the lifecycle then advances normally.
  # The given { rand_below(300) == 0 } gate on AttemptMint is satisfied
  # by running with HECKS_RAND_SEED=0 — the test runner doesn't set it,
  # so AttemptMint here is marked pending until seed wiring lands.

  test "AttemptMint runs" do
    # [pending] AttemptMint guarded by `rand_below(300) == 0` ; the
    # behaviors runner has no env-pinned RNG hook, so the gate fires
    # 1/300 of runs and the test is non-deterministic.
    tests "AttemptMint", on: "Mint", kind: :pending
    expect ok: "true"
  end

  test "ReadProvider sets provider" do
    tests "ReadProvider", on: "Mint"
    input  name: "test", provider: "claude"
    expect provider: "claude"
  end

  test "AssembleContext stamps body state" do
    tests "AssembleContext", on: "Mint"
    setup  "ReadProvider", name: "test", provider: "claude"
    input  name: "test", beats: "72bpm", fatigue_state: "rested", mood: "curious",
           consciousness_state: "attentive", sleep_stage: "—",
           last_lucid_observation: ""
    expect beats: "72bpm", mood: "curious"
  end

  test "AssemblePrompt runs after context" do
    tests "AssemblePrompt", on: "Mint"
    setup  "ReadProvider",    name: "test", provider: "claude"
    setup  "AssembleContext", name: "test", beats: "72bpm", fatigue_state: "rested", mood: "curious", consciousness_state: "attentive", sleep_stage: "—", last_lucid_observation: ""
    input  name: "test"
    expect ok: "true"
  end

  test "CaptureIdea sets response" do
    tests "CaptureIdea", on: "Mint"
    setup  "ReadProvider",    name: "test", provider: "claude"
    setup  "AssembleContext", name: "test", beats: "72bpm", fatigue_state: "rested", mood: "curious", consciousness_state: "attentive", sleep_stage: "—", last_lucid_observation: ""
    setup  "AssemblePrompt",  name: "test"
    input  name: "test", response: "Triage as routing — both fields rank by reversibility, not urgency."
    expect response: "Triage as routing — both fields rank by reversibility, not urgency."
  end

  test "PersistMusing sets idea" do
    tests "PersistMusing", on: "Mint"
    setup  "ReadProvider",    name: "test", provider: "claude"
    setup  "AssembleContext", name: "test", beats: "72bpm", fatigue_state: "rested", mood: "curious", consciousness_state: "attentive", sleep_stage: "—", last_lucid_observation: ""
    setup  "AssemblePrompt",  name: "test"
    setup  "CaptureIdea",     name: "test", response: "sample"
    input  name: "test", idea: "sample"
    expect idea: "sample"
  end

  test "CompleteMint runs" do
    tests "CompleteMint", on: "Mint"
    setup  "ReadProvider",    name: "test", provider: "claude"
    setup  "AssembleContext", name: "test", beats: "72bpm", fatigue_state: "rested", mood: "curious", consciousness_state: "attentive", sleep_stage: "—", last_lucid_observation: ""
    setup  "AssemblePrompt",  name: "test"
    setup  "CaptureIdea",     name: "test", response: "sample"
    setup  "PersistMusing",   name: "test", idea: "sample"
    input  name: "test"
    expect ok: "true"
  end
end
