# Dream-study test-gate Gemfile (in_memory_full_night).
#
# Reuses Hecks's gem environment via eval_gemfile so `bundle exec rspec`
# from this directory resolves the same gems Hecks itself depends on.
# Mirrors sibling Phase 0 directories.

