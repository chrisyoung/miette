# sleep_final_light.fixture — Cycle 8 final-light (last NREM phase before
# auto-wake). No timer (NREM), just moon + cycle/8 — final_light. The renderer
# uses sleep_stage verbatim as the phase_label for non-lucid-REM.
heki_seeds:
  mood:           {current_state: "sleeping", creativity_level: 0.5, precision_level: 0.5}
  heartbeat:      {fatigue_state: "alert", fatigue: 0.1, pulse_rate: 1.0, flow_rate: "steady", pulses_since_sleep: 0}
  consciousness:  {state: "sleeping", sleep_stage: "final_light", sleep_cycle: 8, sleep_total: 8, phase_ticks: 0, dream_pulses: 0, dream_pulses_needed: 5, is_lucid: "no", sleep_summary: ""}
  tick:           {cycle: 100}
expected_render: "{{MOON}} cycle 8/8 — final_light"
