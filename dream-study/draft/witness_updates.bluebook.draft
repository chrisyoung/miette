#     # ReflectionOccurred).
#     true
#   end
#
#   command "Observe" do
#     # ... unchanged ...
#   end
#
#   command "ReflectOnObservation" do
#     # ... unchanged ...
#   end
# end

# ----- Notes for the Phase 8 PR ------------------------------
#
# When Phase 1+3 merge (Ruby DSL + Rust parser for process_manager) :
#
#   1. Insert the four new policies into mind/awareness/witness.bluebook
#      (after line 96, before the closing end). They fire as soon as
#      the PMs that emit the events are loaded.
#   2. Add the invariant block to the aggregate body (lines 39-64
#      shape).
#   3. Run Phase 0c's cross_aggregate_helper — verify that
#      LucidityBegan / LucidityEnded / MindRejoinedDream /
#      DreamStudyPublished all cascade into Witness.Observed.
#   4. Update glossary entries (Phase 10) — see glossary_lock.bluebook.draft.
#
