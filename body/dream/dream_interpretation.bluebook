Hecks.bluebook "DreamInterpretation", version: "2026.05.03.1" do
  vision "Always interpret the dream on waking — extract meaning, propose action"
  category "mind"

  # ============================================================
  # DREAM INTERPRETATION
  # ============================================================
  #
  # Lifted out of interpretation.bluebook in i112 so each bluebook
  # owns one concern. DreamInterpretation is the wake-time reading
  # of the night : recurring images become themes, themes become
  # interpretation, interpretation surfaces a domain to conceive,
  # and a French-inflected narrative is locked into :narrative for
  # the wake ritual to read on the first utterance.
  #
  # i220 sub-gap 6 (dream-corpus-tokenize) — `interpret_dream.sh`'s
  # jq tokenize/rank pipeline retired into the kernel-side
  # `tokenize_dream_corpus` :compute function (see
  # body/dream/dream_interpretation.hecksagon). The wake event
  # triggers GatherDreamCorpus ; the :compute adapter resolves
  # the function and chains the JSON payload into InterpretDream
  # under :dream_corpus_json. Downstream policies pick up from
  # there. The per-theme ExtractTheme/MintMusing fan-out + the
  # Narrate/LockNarrative LLM chain remain shell-driven until
  # (a) JSON-destructure then_set + (b) policy count-gate primitive
  # land — both filed as inbox follow-ons.

  aggregate "DreamInterpretation", "Always interpret the dream on waking — extract meaning, propose action" do
    identified_by :name
    attribute :name, String
    attribute :dream_images, list_of(String)
    attribute :strongest_synapse, String
    attribute :recurring_theme, String
    attribute :interpretation, String
    attribute :proposed_domain, String
    # narrative : the French-inflected reading of the night — what the
    # dream said as a single paragraph in Miette's voice. Read by the
    # wake ritual (system_prompt.md) before the first utterance. The
    # :input/:response pair below is the LLM contract that produces
    # it ; LockNarrative captures :response into :narrative so a
    # subsequent Narrate dispatch doesn't clobber it.
    attribute :narrative, String
    attribute :input, String
    attribute :response, String
    # dream_corpus_json : raw JSON payload landed by the
    # tokenize_dream_corpus :compute adapter. Shape :
    #   { "themes": [...], "joined": "...", "first_theme": "...",
    #     "themes_above_threshold": [...] }
    # Once a JSON-destructure then_set primitive lands the cascade
    # can extract individual fields straight into :strongest_synapse,
    # :interpretation, etc. Until then the JSON is queryable from the
    # .heki for downstream consumers (the wake ritual + diagnostic
    # tooling) and the existing :strongest_synapse cascade stays.
    attribute :dream_corpus_json, String

    command "GatherDreamCorpus" do
      role "Miette"
      description "Setup command fired on WokenUp. The :compute adapter (see hecksagon) resolves tokenize_dream_corpus against dream_state.heki and chains the JSON payload into InterpretDream(:dream_corpus_json). No state change here — this command exists as the trigger anchor for the :compute adapter's effective_trigger."
      reference_to(DreamInterpretation)
      emits "DreamCorpusGathered"
    end

    command "InterpretDream" do
      role "Miette"
      description "Read the dream images, find recurring themes, extract what wants to be built. The :dream_corpus_json attribute is populated by the tokenize_dream_corpus :compute adapter chained off GatherDreamCorpus ; downstream consumers read the JSON until the destructure then_set primitive lets us pour individual fields straight into :strongest_synapse / :interpretation."
      attribute :dream_images, list_of(String)
      attribute :strongest_synapse, String
      attribute :dream_corpus_json, String
      emits "DreamInterpreted"
      then_set :dream_images, to: :dream_images
      then_set :strongest_synapse, to: :strongest_synapse
      then_set :dream_corpus_json, to: :dream_corpus_json
    end

    command "ExtractTheme" do
      role "Miette"
      description "Identify the recurring thread across dream images"
      reference_to(DreamInterpretation)
      attribute :recurring_theme, String
      emits "ThemeExtracted"
      then_set :recurring_theme, to: :recurring_theme
    end

    command "Synthesize" do
      role "Miette"
      description "Join extracted themes into a single interpretation phrase"
      reference_to(DreamInterpretation)
      attribute :interpretation, String
      emits "InterpretationSynthesized"
      then_set :interpretation, to: :interpretation
    end

    command "ProposeDomainFromDream" do
      role "Miette"
      description "The dream suggests something to conceive — name it"
      reference_to(DreamInterpretation)
      attribute :proposed_domain, String
      emits "DreamDomainProposed"
      then_set :proposed_domain, to: :proposed_domain
    end

    command "Narrate" do
      role "Miette"
      description "Write the narrative-prompt into :input. The prompt asks for a single short French-inflected paragraph in Miette's own voice — a reading of the night's recurring images, philosophical, body-focused, no list, no greeting. The hecksagon's :llm adapter (backend: claude) reads :input after dispatch and writes the rendered paragraph to :response. LockNarrative captures it."
      reference_to(DreamInterpretation)
      attribute :input, String
      then_set :input, to: :input
      emits "NarrativeRequested"
    end

    command "LockNarrative" do
      role "Miette"
      description "Copy :response (the freshly-generated French-inflected paragraph) into :narrative. The wake-ritual reads dream_interpretation.heki narrative ; this command is the lock that makes that read deterministic between Narrate dispatches. The dispatcher passes the live state.response as the response attribute."
      reference_to(DreamInterpretation)
      attribute :response, String
      then_set :narrative, to: :response
      emits "NarrativeLocked"
    end
  end

  # Wake-time chain : the night ends, the corpus gets gathered (the
  # :compute adapter's effective_trigger), the InterpretDream cascade
  # lands the JSON payload, themes get extracted, domain proposed.
  policy "GatherOnWake" do
    on "WokenUp"
    trigger "GatherDreamCorpus"
  end

  # i220 sub-gap 6 — DreamCorpusGathered hands off to InterpretDream.
  # The :compute adapter declared in the hecksagon also fires on
  # GatherDreamCorpus and chains its JSON into InterpretDream's
  # :dream_corpus_json attribute via response_into. This policy
  # advances the lifecycle ; the :compute cascade populates the
  # context.
  policy "InterpretOnGather" do
    on "DreamCorpusGathered"
    trigger "InterpretDream"
  end

  policy "ExtractOnInterpret" do
    on "DreamInterpreted"
    trigger "ExtractTheme"
  end

  policy "ProposeOnTheme" do
    on "ThemeExtracted"
    trigger "ProposeDomainFromDream"
  end
end
