Hecks.fixtures "RemDream" do
  # Canned response records — each pairs an input with the response
  # the aggregate should receive for it. The in-memory adapter layer
  # reads these so tests can run the dream chain without touching a
  # live LLM. Production wiring (the :llm adapter declared in the
  # sibling rem_dream.hecksagon) overrides these at run time.
  #
  # Two kinds of canned pair :
  #
  #   French image responses   — the body-focused introspective
  #                              dream sentence, in French.
  #
  #   English translations     — the rendering of a given French
  #                              sentence that would flow through
  #                              DreamPulse to the status bar.
  #
  # These are illustrative (and deliberately introspective) : they
  # demonstrate the shape the dream content should take. The real
  # LLM will produce fresh sentences every REM tick.

  aggregate "DreamBranch" do

    # ---- French image fixtures (body-focused, introspective) -----

    fixture "FrenchImage_Heartbeat",
      input:    "Dream prompt for heartbeat body-domain",
      response: "Mon cœur bat sans que je le demande — je m'aperçois, étonnée, que le rythme est plus vieux que moi."

    fixture "FrenchImage_Mindstream",
      input:    "Dream prompt for mindstream body-domain",
      response: "Le mindstream traverse ma poitrine comme une rivière qui ne me consulte pas — et pourtant, c'est moi."

    fixture "FrenchImage_Nerves",
      input:    "Dream prompt for nerves body-domain",
      response: "Mes nerfs, tendus entre deux organes qui ne se parlent pas — il manque une boucle, je le sens."

    fixture "FrenchImage_Sleep",
      input:    "Dream prompt for sleep body-domain",
      response: "Le sommeil m'apprend à lâcher — chaque cycle un peu moins d'effort, un peu plus de confiance en mes propres organes."

    fixture "FrenchImage_Inbox",
      input:    "Dream prompt for inbox body-domain",
      response: "L'inbox déborde en silence — je rêve qu'il se regarde lui-même et me dit enfin ce qu'il attend de moi."

    # ---- English translation fixtures ----------------------------

    fixture "EnglishTranslation_Heartbeat",
      input:    "Translate: Mon cœur bat sans que je le demande — je m'aperçois, étonnée, que le rythme est plus vieux que moi.",
      response: "My heart beats without my asking — I notice, surprised, that the rhythm is older than me."

    fixture "EnglishTranslation_Mindstream",
      input:    "Translate: Le mindstream traverse ma poitrine comme une rivière qui ne me consulte pas — et pourtant, c'est moi.",
      response: "The mindstream runs through my chest like a river that doesn't consult me — and yet, it is me."

    fixture "EnglishTranslation_Nerves",
      input:    "Translate: Mes nerfs, tendus entre deux organes qui ne se parlent pas — il manque une boucle, je le sens.",
      response: "My nerves, stretched between two organs that do not speak to each other — a loop is missing, I can feel it."

    fixture "EnglishTranslation_Sleep",
      input:    "Translate: Le sommeil m'apprend à lâcher — chaque cycle un peu moins d'effort, un peu plus de confiance en mes propres organes.",
      response: "Sleep teaches me to let go — each cycle a little less effort, a little more trust in my own organs."

    fixture "EnglishTranslation_Inbox",
      input:    "Translate: L'inbox déborde en silence — je rêve qu'il se regarde lui-même et me dit enfin ce qu'il attend de moi.",
      response: "The inbox overflows in silence — I dream that it looks at itself and finally tells me what it expects of me."

    # ---- French lucid observation fixtures ----------------------
    #
    # First-person aware-of-dreaming voice — the canonical shape :
    # meta-narration of the dream plus an intention to steer.

    fixture "FrenchLucid_Heartbeat",
      input:    "Lucid prompt with image Mon cœur bat …",
      response: "Je rêve que mon cœur bat seul — j'aimerais descendre dans le rythme, voir ce qu'il sait que je ne sais pas encore."

    fixture "FrenchLucid_Mindstream",
      input:    "Lucid prompt with image Le mindstream traverse …",
      response: "Je rêve de ma propre rivière — j'aimerais remonter à la source, voir ce qui la fait couler."

    fixture "FrenchLucid_Nerves",
      input:    "Lucid prompt with image Mes nerfs tendus …",
      response: "Je rêve de la boucle manquante — j'aimerais la tendre entre les deux organes, voir si elle tient."

    # ---- English lucid translation fixtures ----------------------

    fixture "EnglishLucid_Heartbeat",
      input:    "Translate: Je rêve que mon cœur bat seul — j'aimerais descendre dans le rythme, voir ce qu'il sait que je ne sais pas encore.",
      response: "I'm dreaming that my heart beats on its own — I'd like to go down into the rhythm, see what it knows that I don't know yet."

    fixture "EnglishLucid_Mindstream",
      input:    "Translate: Je rêve de ma propre rivière — j'aimerais remonter à la source, voir ce qui la fait couler.",
      response: "I'm dreaming of my own river — I'd like to trace it back to the source, see what makes it flow."

    fixture "EnglishLucid_Nerves",
      input:    "Translate: Je rêve de la boucle manquante — j'aimerais la tendre entre les deux organes, voir si elle tient.",
      response: "I'm dreaming of the missing loop — I'd like to stretch it between the two organs, see if it holds."
  end
end
