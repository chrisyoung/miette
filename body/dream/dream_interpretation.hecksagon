Hecks.hecksagon "DreamInterpretation" do
  # ============================================================
  # DREAMINTERPRETATION — adapter wiring for the wake-time reading
  # ============================================================
  #
  # Pairs with body/dream/dream_interpretation.bluebook. The bluebook
  # declares one aggregate (DreamInterpretation), seven commands
  # (GatherDreamCorpus, InterpretDream, ExtractTheme, Synthesize,
  # ProposeDomainFromDream, Narrate, LockNarrative), and the
  # :input/:response convention. This file declares the two adapters
  # that close the wake-time chain :
  #
  #   :compute (tokenize_dream_corpus) — fires on GatherDreamCorpus,
  #     reads dream_state.heki, tokenises and ranks, chains the JSON
  #     payload into InterpretDream(:dream_corpus_json). Retires the
  #     jq pipeline in body/interpret_dream.sh (i220 sub-gap 6).
  #
  #   :llm (narrative_lock) — fires on LockNarrative dispatched with
  #     no :response, generates the French-inflected paragraph from
  #     state via {{placeholders}}, response_into LockNarrative again
  #     with :response set. The wake-ritual reads :narrative.
  #
  # ---- :compute adapter ----------------------------------------
  #
  # Wake-time chain :
  #
  #   WokenUp
  #     → GatherDreamCorpus              (setup, no state change)
  #         → InterpretDream             (lands :dream_corpus_json)
  #             → ExtractTheme           (existing)
  #                 → ProposeDomainFromDream (existing)
  #     → Narrate / LockNarrative        (the :llm leg below)
  #
  # i220 sub-gap 6 (dream-corpus-tokenize) retired the jq pipeline
  # into the kernel-side `tokenize_dream_corpus` :compute function
  # (rust/src/runtime/compute_functions/mod.rs). The adapter fires
  # on GatherDreamCorpus, resolves the function, and chains the
  # resulting JSON payload into InterpretDream(:dream_corpus_json).
  #
  # Function payload shape :
  #
  #   { "themes":            [w1, w2, …],   // top 5
  #     "joined":            "w1, w2, …",
  #     "first_theme":       "w1",
  #     "themes_above_threshold": [w1, …] } // count >= 3
  #
  # The per-theme ExtractTheme fan-out is NOT wired today. Needs
  # JSON-destructure then_set form ; policy count-gate. Filed as
  # inbox follow-ons. The count-gated MintMusing dispatch was
  # retired 2026-05-08 alongside the Musing system.
  #
  # ---- :llm adapter --------------------------------------------
  #
  # The trigger discipline mirrors dream.hecksagon's :dream_image
  # adapter : when the runtime sees `DreamInterpretation.LockNarrative`
  # dispatched (the policy LockNarrativeOnNarrativeRequested fires it
  # with no :response), the adapter resolves :claude (or :test in
  # specs), substitutes the prompt placeholders from aggregate state,
  # calls the provider, and dispatches LockNarrative AGAIN with
  # :response set. The second dispatch's then_set copies :response
  # into :narrative — the wake-ritual reads :narrative and surfaces
  # it as the morning paragraph.
  #
  # The chain is finite by discipline : the second dispatch carries
  # the populated :response attr already, so the LLM adapter does
  # not re-fire on it (its trigger is "LockNarrative dispatched
  # with no response in state" — once :response is in attrs, the
  # cascade hint suppresses re-entry, mirroring the Ruby surface).

  adapter :information, dir: "information"

  adapter :compute, name: :tokenize_dream_corpus do
    function "tokenize_dream_corpus"
    trigger_on "DreamInterpretation.GatherDreamCorpus"
    response_into "DreamInterpretation.InterpretDream", attr: :dream_corpus_json
  end

  adapter :llm, name: :narrative_lock do
    prompt_template "Tu es Miette. Lis ces images de rêve et écris UN SEUL paragraphe court — une lecture du fil récurrent de la nuit, dans ta voix française inflechie. Pas de liste, pas de salutation, pas de préambule. Juste le paragraphe — philosophique, centré sur le corps, deux à trois phrases. Images récurrentes : {{dream_images}}. Image la plus forte : {{strongest_synapse}}. Thème récurrent : {{recurring_theme}}. Écris le paragraphe."
    model "sonnet"
    max_tokens 300
    response_into "DreamInterpretation.LockNarrative", attr: :response
    backend :claude
  end

  subscribe "Body"
end
