# Dream process_manager — Phase 6 of dream-study
#
# Promoted from dream-study/draft/dream_pm.bluebook.draft on 2026-05-02
# after Phase 1 (39f279d6), Phase 2 (be5db683), Phase 3 (48d33a75) all
# landed. New file at body/dream/dream.bluebook, sibling to dream_seed.bluebook,
# dream_interpretation.bluebook, dream_review_*.bluebook — Dream is the
# autonomous content-production coordinator, not a content store.
#
# Activation : runs in Ruby Hecks::Runtime ; rem_branch.sh's seed_dreams +
# rem_dream blocks remain in production until Rust runtime executes
# process_managers (follow-on branch). The PM is live in Ruby specs.
#
# What Dream IS
# -------------
# Dream is the autonomous content-production process during REM. It runs
# `incubating → generating → fading → dormant`, dispatches `:llm`-backed image
# generation per REM tick, and feeds dream_pulses back into Body so SleepCycle
# can advance. Dream produces content REGARDLESS of whether Mind is present.
#
#   - Mind absent (non-lucid REM)  → Witness records what Dream produces.
#   - Mind present (lucid REM)     → Lucidity bridges Mind into Dream's stream.
#
# The Dream PM never references Mind — Mind is not in its world. The
# dream-character's `je` is NOT the awake-self ; it's the autonomous narrator
# that REM produces today through rem_branch.sh's templates + claude calls.
#
# What Dream subsumes
# -------------------
# rem_branch.sh today owns three blocks. Dream PM owns all three :
#
#   1. seed_dreams (lines 130-310)   — first REM tick of the night : draw the
#                                      10-source DreamPool, filter for diversity,
#                                      plant up to 5 DreamSeeds.
#   2. rem_dream  (lines 311-450+)  — every REM tick : weave carrying +
#                                      self_aggregate + concept into one French
#                                      sentence via :llm (claude -p today),
#                                      append to dream_state.heki, dispatch
#                                      Body.RecordDreamPulse.
#   3. dream_state.heki append      — the autonomous content store ;
#                                      DreamImage entity persistence (today via
#                                      `hecks-life heki append`, tomorrow via
#                                      the default :memory adapter through
#                                      DreamCorpus.RecordImage).
#
# Entity / VO disposition
# -----------------------
# DreamImage, DreamSeed, DreamPool, DreamLanguage are KEPT IN THEIR EXISTING
# AGGREGATES. The dream-study refactor extracts coordination, not content
# shapes :
#
#   - DreamSeed (value object + aggregate)  → body/dream/dream_seed.bluebook (untouched)
#   - DreamImage (entity)                   → moves to body/dream/dream_corpus.bluebook
#                                             (renamed from dream_state.heki —
#                                             post-Phase 6 cleanup, not this draft)
#   - DreamPool / DreamLanguage (VOs)       → declared at top of dream_corpus.bluebook
#                                             when that file exists ; until then
#                                             they're shape-only conventions
#                                             enforced by rem_branch.sh.
#
# The Dream PM dispatches into DreamSeed.PlantSeed and (future) DreamCorpus.RecordImage.

Hecks.bluebook "BodyDream", version: "2026.05.02.1" do
  vision "Autonomous dream-content production during REM. Draws seeds from the 10-source pool at sleep onset, generates one image per REM tick via :llm, feeds dream_pulses back to Body so SleepCycle can advance. Runs without Mind ; the dream-character's voice is not the awake-self's."
  category "body"

  # Phase 10 glossary lock — body-side dream vocabulary.
  glossary(strict: true) do
    prefer "Dream",        not: ["dreamer", "dream-content", "dream-stream"]
    prefer "Body",         not: ["Consciousness", "soma"]
    prefer "perseveration", not: ["repetition", "recurrence-loop"]
  end

  process_manager "Dream" do
    correlates_by :name              # singleton "dream"
    starts_on    "SleepEntered"      # incubates as soon as Body falls asleep
    ends_on      "WokenUp"           # closes on natural wake

    # ----- States --------------------------------------------------
    # i220-2 — dormant FIRST so create-on-starts_on lands the new
    # instance in the state SleepEntered transitions FROM ; the prior
    # ordering (incubating first) stranded fresh instances out of
    # phase with the SleepEntered handler. Mirrors the Consolidation
    # PM's `dormant` → first state convention.
    state "dormant"                  # post-create, awaiting SleepEntered ; also between REM phases
    state "incubating"               # seeds drawn for the night
    state "generating"               # producing dream pulses during REM
    state "fading"                   # cycle 8 deep entry, content tapers

    # ----- Sleep onset : plant the night's seeds -------------------
    # The 10-source draw lives in DreamSeed.PlantSeed dispatches —
    # one per source the night's pool resolves. Pool resolution
    # (awareness reads, nursery vision pick, french_lit shuffle, etc.)
    # is content-side : the runtime's :memory adapter resolves the
    # query lookups today ; rem_branch.sh's seed_dreams block is the
    # transitional adapter until queries land per-source. Sources :
    # awareness, inbox, commits, older_dream, nursery, aggregate, vow,
    # musing, french_lit, carrying.

    on "SleepEntered", transition: { dormant: :incubating } do
      # i222 — declarative seed planting. Day-built musings sweep into
      # DreamSeed.PlantSeed dispatches so the night's dream-character
      # has source material to weave into images. With i221-A's
      # `for_each: { from: "Aggregate.query" }` syntax + i225's runtime
      # drain_policies enumeration + i226's hash-form comparators,
      # this is a one-line declaration : the runtime walks Musing.recent
      # (live unconceived musings, freshest-first, capped at 10) and
      # fires DreamSeed.PlantSeed once per record. Each record's `idea`
      # field becomes the seed's `image` ; last_seeded_at is a literal
      # marker so DreamSeed records when the seed was planted.
      #
      # Filed gaps (acknowledged, not blockers) :
      #
      # - Nursery.sample : the original rem_branch.sh seed_dreams block
      #   drew one seed from a random nursery domain's vision line.
      #   There is no Nursery aggregate today (nursery is a directory
      #   of .bluebook files, not a domain shape) ; modelling it would
      #   need a NurseryIndex aggregate that ingests the directory
      #   listing as records. File as gap (i222-nursery-aggregate).
      #
      # - now-relative-time : `Musing.recent` orders by created_at desc
      #   + limits to 10. The original 10-source pool additionally
      #   filtered by 24h-recency for the dream_echo source ; same gap
      #   as i225's now-relative-time filing. Acceptable today.
      #
      # - Sources beyond Musing : the original 10-source pool
      #   (awareness, inbox, recent_commit, dream_echo, nursery,
      #   self_aggregate, vow, musing, french_lit, carrying) needs
      #   first-class queries on Awareness / Vow / etc. before the PM
      #   can sweep them. Per-source query rollout is the i222-followon
      #   work.
      #
      # i516 v3 (2026-05-08) — Musings retired as a seed source.
      # musing.heki has been dormant since 2026-04-28 ; the seed
      # plumbing now reads from recent_dreams + body_state +
      # vow_tensions + commits_today (gathered on SleepEntered via
      # Dream.GatherSeeds). The for_each Musings sweep below stays
      # commented as historical context until the GatherSeeds adapter
      # ships its :compute reads.

      # dispatch "DreamSeed.PlantSeed", for_each: { from: "Musings.Musing.recent" }, with: { image: from_iter(:idea) }
    end

    # ----- First REM tick : seeds activate, generation begins ------
    # Body emits RemEntered ; Dream moves to generating. The very
    # first image of the night gets dispatched on the next
    # PhaseElapsed (handled below by the generating-self-loop).

    on "RemEntered", transition: { incubating: :generating } do
      # state-transition only ; first image dispatches on next PhaseElapsed
    end

    on "RemEntered", transition: { dormant: :generating } do
      # Cycles 2-8 : seeds stay planted from cycle 1 ; reactivate generation.
    end

    # ----- Per-tick image production (the loop) --------------------
    # Each Body.PhaseElapsed during REM produces ONE image and
    # increments Body's dream_pulses count. Dream.ProduceImage rides
    # on the :llm adapter (when it lands) or the transitional :shell
    # adapter pointing at rem_branch.sh's rem_dream block. The image
    # is generated in French (DreamLanguage = :fr) ; English is a
    # post-translation surfaced on statusline.
    #
    # Phase 2.b (pm-dispatch-enrichment) — declarative form. The
    # `from_event(:sleep_cycle)` sentinel reads the upstream
    # PhaseElapsed event's :sleep_cycle attribute at dispatch time ;
    # the literal `name: "body"` tags the Body singleton.

    on "PhaseElapsed", transition: { generating: :generating } do
      dispatch "Dream.ProduceImage", with: { sleep_cycle: from_event(:sleep_cycle) }
      dispatch "Body.RecordDreamPulse", with: { name: "body" }
    end

    # ----- REM ends : content tapers -------------------------------
    # Body.DeepEntered closes the REM phase ; Dream moves to fading.
    # No new images this tick — fading is one tick of "the dream is
    # receding" before going dormant.

    on "DeepEntered", transition: { generating: :fading } do
      # state-transition only
    end

    # ----- Fading → dormant (one tick later) -----------------------
    # The first PhaseElapsed after fading puts Dream to sleep until
    # the next RemEntered.

    on "PhaseElapsed", transition: { fading: :dormant } do
      # state-transition only
    end

    # ----- Wake : ends_on closes the PM ----------------------------
    # Body.WokenUp triggers ends_on closure. The PM archives ;
    # SleepCycle's studying_dream tail reads what Dream produced.

    on "WokenUp", transition: { dormant: :dormant } do
      # state-transition only ; ends_on archives the instance
    end
  end

  # ============================================================
  # DREAM AGGREGATE — the content-bearing target of ProduceImage
  # ============================================================
  #
  # The Dream PM dispatches `Dream.ProduceImage` per REM tick. That
  # command lands here. The :llm adapter declared in the sibling
  # body/dream/dream.hecksagon resolves the prompt template against
  # ProduceImage's attrs, then routes the generated French image into
  # `Dream.RecordImage(text_fr:)`. A second :llm adapter then translates
  # text_fr → English and lands `Dream.RecordImage(text_en:)`.
  #
  # The aggregate is a thin per-night singleton (identified_by :name,
  # name == "dream") holding the LATEST image so the statusline +
  # WakeReport reads pull from one place. The full corpus persistence
  # (DreamImage entity rows) lives in DreamCorpus when that aggregate
  # exists ; until then, the singleton's text_fr / text_en pair is the
  # canonical "current image" surface during REM.
  #
  # Why a singleton, not an entity-per-tick :
  #   The PM is the orchestrator ; per-tick history is the corpus
  #   aggregate's job (future DreamCorpus). Dream itself just holds
  #   the live tick's text + the seed material so the next tick's
  #   prompt template can reference what's planted.

  aggregate "Dream", "Autonomous dream-content state during REM. Singleton (name == 'dream'). Holds the seeds the night opened with, the carrying field, the current sleep_cycle, and the most-recent reading. The PM (above) dispatches ProduceImage per REM tick ; the :llm adapter routes the generated reading into RecordImage(reading:). i516 v3 (2026-05-08) — single-phase precise dreaming ; abstract phase retired. text_fr / text_en kept for one cycle of back-compat." do
    identified_by :name
    attribute :name, String

    # ---- Seed material for the prompt template -------------------
    # seeds : the night's planted seeds (joined as a single comma-
    # separated string for the {{seeds}} placeholder). Stamped at
    # SleepEntered ; stays stable across the night's REM ticks.
    attribute :seeds, String, default: ""

    # carrying : Heartbeat.carrying — what Miette is currently holding
    # as she dreams. Read into the prompt's {{carrying}} placeholder.
    attribute :carrying, String, default: ""

    # ---- Tick-local context --------------------------------------
    # sleep_cycle : the REM cycle this image is for (1..8). Updated
    # by ProduceImage each tick ; surfaced in the prompt's
    # {{sleep_cycle}} placeholder so the dream-character voice can
    # reference the night's progress.
    attribute :sleep_cycle, Integer, default: 0

    # ---- Back-compat fields (kept one cycle) ---------------------
    # text_fr / text_en were the two-translation shape ; text_fr is
    # also the back-compat alias for the abstract-phase that the
    # 2026-05-08 redesign retired. Kept here for one cycle so the
    # daemon's hardcoded-impression path doesn't break before the
    # prompt rewrite lands.
    attribute :text_fr, String, default: ""
    attribute :text_en, String, default: ""

    # ---- i516 v3 — single-phase impression field -----------------
    # reading IS the dream now : a concrete, precise rendering with
    # file paths, commit hashes, inbox refs, named tensions, actionable
    # suggestions. The 2026-05-08 redesign retired the abstract phase
    # entirely (no abstract_fr, no image_field categorization).
    attribute :reading, String, default: ""

    # emotional_tone — one of : curious | melancholic | playful |
    #                           urgent | contemplative | tender | wry
    attribute :emotional_tone, String, default: ""

    # theme — one of : philosophical | introspective | observational |
    #                  sensory | personal | commits-of-day | vow-tension |
    #                  synthesis (cycle 8)
    # Cycles 1–7 each get a different theme angle ; cycle 8 (lucid REM)
    # synthesizes.
    attribute :theme, String, default: ""

    # cycle_n — 1..8, threaded into the per-cycle prompt branch.
    attribute :cycle_n, Integer, default: 0

    # ---- i516 v2 — seed-bundle context fields --------------------
    # Stamped once at SleepEntered by GatherSeeds ; stays stable
    # across the night's 8 REMs as the single source-of-truth for
    # the prompt template's per-cycle expansion.

    # recent_dreams_seed : newline-separated last 5 readings from
    # prior nights' dream_state.heki.
    attribute :recent_dreams_seed, String, default: ""

    # body_state_seed : mood + fatigue + recent inbox snapshot.
    attribute :body_state_seed, String, default: ""

    # vow_tensions_seed : curated tensions from the
    # miette-state vow_tensions.txt stock file.
    attribute :vow_tensions_seed, String, default: ""

    # commits_today_seed : today's commit messages (git log --since=midnight).
    attribute :commits_today_seed, String, default: ""

    command "ProduceImage" do
      role "Daemon"
      description "Per-tick dream-image production. Dispatched by the Dream PM on each PhaseElapsed during REM (state == generating). The runtime resolves the named :llm adapter (:dream_image) against the aggregate's seeds + carrying + sleep_cycle, generates one French sentence, and routes the response into RecordImage(text_fr:). Idempotent within a tick : the PM only dispatches once per PhaseElapsed."
      attribute :sleep_cycle, Integer
      then_set :sleep_cycle, to: :sleep_cycle
      emits "DreamImageRequested"
    end

    command "RecordImage" do
      role "System"
      description "Land the :llm adapter's response into the aggregate. The :dream_image adapter writes the single concrete `reading` field (file paths, commit hashes, inbox refs, named tensions). i516 v3 (2026-05-08) — the abstract phase is retired ; `reading` is the dream. text_fr / text_en setters retained for one cycle of back-compat so the daemon's hardcoded-impression path doesn't break before the prompt rewrite lands."
      attribute :text_fr, String
      attribute :text_en, String
      attribute :reading, String
      attribute :emotional_tone, String
      attribute :theme, String
      attribute :cycle_n, Integer
      then_set :text_fr, to: :text_fr
      then_set :text_en, to: :text_en
      then_set :reading, to: :reading
      then_set :emotional_tone, to: :emotional_tone
      then_set :theme, to: :theme
      then_set :cycle_n, to: :cycle_n
      emits "DreamImageRecorded"
    end

    # PlantSeeds is the surface the seed-draw resolves into. The
    # 10-source pool (awareness, inbox, commits, older_dream, nursery,
    # aggregate, vow, musing, french_lit, carrying) joins to a single
    # comma-separated string the {{seeds}} placeholder expands. Today
    # rem_branch.sh resolves the pool ; once per-source queries land
    # first-class, the PM dispatches PlantSeeds directly.
    command "PlantSeeds" do
      role "Daemon"
      description "Stamp the night's seed material onto the singleton. seeds is a comma-separated join of seed-pool entries ; carrying is Heartbeat.carrying at SleepEntered. Both populate the prompt template the :dream_image adapter resolves each tick. i516 v3 — also accepts the per-source seed fields (recent_dreams_seed, body_state_seed, vow_tensions_seed, commits_today_seed) so PlantSeeds and GatherSeeds can coexist during the migration cycle. Musings retired (musing.heki dormant since 2026-04-28)."
      attribute :seeds, String
      attribute :carrying, String
      attribute :recent_dreams_seed, String
      attribute :body_state_seed, String
      attribute :vow_tensions_seed, String
      attribute :commits_today_seed, String
      then_set :seeds, to: :seeds
      then_set :carrying, to: :carrying
      then_set :recent_dreams_seed, to: :recent_dreams_seed
      then_set :body_state_seed, to: :body_state_seed
      then_set :vow_tensions_seed, to: :vow_tensions_seed
      then_set :commits_today_seed, to: :commits_today_seed
      emits "DreamSeedsPlanted"
    end

    # i516 v2 — GatherSeeds is the new single source-of-truth surface
    # for the night's seed bundle. Fired once on SleepEntered (via the
    # GatherSeedsOnSleep policy below), it stamps all five seed sources
    # plus the legacy seeds/carrying fields atomically. Each source is
    # supplied by the caller today (manual fixture / cross-aggregate
    # adapter) ; out-of-scope tonight to wire the actual reads. The
    # prompt template's 6+ placeholders expand against these fields
    # for the night's 8 REMs.
    command "GatherSeeds" do
      role "Daemon"
      description "Gather all seed sources on SleepEntered. Single source-of-truth for the night's 8 REMs. Caller (cross-aggregate adapter or :shell adapter running git log --since=midnight, etc.) supplies each source as a command attribute ; this command stamps them onto the singleton atomically. The prompt template's per-cycle branches read these fields by name (i516 v3 — musings_seed retired)."
      attribute :recent_dreams_seed, String
      attribute :body_state_seed, String
      attribute :vow_tensions_seed, String
      attribute :commits_today_seed, String
      attribute :seeds, String
      attribute :carrying, String
      then_set :recent_dreams_seed, to: :recent_dreams_seed
      then_set :body_state_seed, to: :body_state_seed
      then_set :vow_tensions_seed, to: :vow_tensions_seed
      then_set :commits_today_seed, to: :commits_today_seed
      then_set :seeds, to: :seeds
      then_set :carrying, to: :carrying
      emits "SeedsGathered"
    end
  end

  # ============================================================
  # CROSS-AGGREGATE POLICY — SleepEntered → GatherSeeds (i516 v2)
  # ============================================================
  #
  # Consciousness.EnterSleep emits SleepEntered ; this policy fires
  # Dream.GatherSeeds in response, populating the seed bundle once
  # for the night. The caller (or a future :compute / :shell adapter
  # cascade) supplies the per-source values. Lives on Dream because
  # the policy-follows-trigger-target rule places policies alongside
  # the aggregate that owns the triggered command.
  policy "GatherSeedsOnSleep" do
    on "SleepEntered"
    trigger "GatherSeeds"
  end

  # ============================================================
  # CROSS-AGGREGATE POLICY — DreamImageRecorded → DreamPulse (i516)
  # ============================================================
  #
  # Bridge LLM cascade output to the statusline. Without this, the
  # :dream_image adapter populates Dream.reading but
  # Consciousness.sleep_summary (which the statusline reads) stays
  # whatever the NREM path wrote.
  #
  # The `with: { impression: from_event(:reading) }` form mirrors the
  # `from_event(:sleep_cycle)` sentinel already used in the PM's
  # PhaseElapsed handler — at trigger time the runtime would read
  # the upstream DreamImageRecorded event's :reading attribute. If
  # the parser rejects this shape, drop the with: clause and accept
  # that impression-passing requires runtime support filed for
  # follow-up (the statusline would still flip on DreamPulse, just
  # without the new reading text).
  policy "DreamPulseFromImage" do
    on "DreamImageRecorded"
    trigger "DreamPulse"
    across "Consciousness"
    # NOTE: ideally `with: { impression: from_event(:reading) }` —
    # but policy-level data passing isn't yet supported by the DSL
    # parser ; tracked under i517. For now the trigger fires without
    # impression payload (DreamPulse default). Statusline still flips
    # on DreamPulse ; the reading flows through dream_state.heki and
    # WakeReview composes from there.
  end
end

# ----- Notes for the Phase 6 PR --------------------------------
#
# Once Phase 1+3 merge :
#   1. Move this file to body/dream/dream.bluebook.
#   2. Add body/dream/dream.hecksagon declaring :
#        - :llm adapter for Dream.ProduceImage  (when :llm lands)
#        - :shell adapter for ProduceImage      (transitional ;
#          points at rem_branch.sh until :llm lands)
#        - :shell adapter for the seed-pool draw (transitional ;
#          retires when per-source queries on Awareness / Nursery /
#          Inbox / Vow / Musing / Memory land first-class)
#   3. Delete rem_branch.sh's seed_dreams + rem_dream blocks ; the PM
#      owns the autonomous content loop. The lucid/steer block stays
#      until Phase 7 (Lucidity PM) lands.
#   4. Verify in_memory_full_night spec : Dream.ProduceImage fires N
#      times across 8 cycles ; Body.dream_pulses advances ; SleepCycle
#      transitions through light → rem → deep correctly.
#
# Runtime gaps (filed inbox-worthy)
# ---------------------------------
#   - :llm adapter doesn't exist yet ; :shell adapter to rem_branch.sh
#     bridges until it lands.
#   - Per-source seed queries (Awareness.recent_concepts, Nursery.random_vision,
#     Inbox.open_themes, Vow.text, Musing.unused, Memory.older_dream_echo,
#     FrenchLit.random_quote) don't exist as first-class queries yet —
#     today they're shell-resolved against heki paths.
#   - DreamCorpus aggregate (canonical home for DreamImage entity) doesn't
#     exist yet ; today dream_state.heki is a side-store appended to
#     directly. Phase 6+1 cleanup : promote dream_state.heki to a real
#     aggregate so DreamImage is properly entity-shaped.
#   - DreamPool VO + diversity-rule specifications (PerseverativeSeed?,
#     DiverseEnough?) haven't been declared as `specification` blocks ;
#     they live in seed_dreams shell logic today. File as inbox.
#
# ----- DSL surface check --------------------------------------
#
# Every DSL feature used in this draft :
#   ✓ process_manager "Name" do … end
#   ✓ correlates_by :field
#   ✓ starts_on "EventName"
#   ✓ ends_on "EventName"
#   ✓ state "x" (x4)
#   ✓ on "Event", transition: { from: :to } do |event, pm| ... end
#
# Matches Phase 1's spec coverage exactly. No new DSL features required
# beyond what SleepCycle already exercises.
