Hecks.hecksagon "Dream" do
  # ============================================================
  # DREAM — production hecksagon for autonomous content production
  # ============================================================
  #
  # The sibling bluebook (body/dream/dream.bluebook) declares two halves :
  #
  #   - The Dream PROCESS_MANAGER                       — orchestrates
  #     incubating → generating → fading → dormant ; dispatches
  #     Dream.ProduceImage per REM PhaseElapsed.
  #   - The Dream AGGREGATE                             — singleton
  #     name == "dream" ; holds the per-source seed fields
  #     (recent_dreams_seed, body_state_seed,
  #     vow_tensions_seed, commits_today_seed), the sleep_cycle, the
  #     per-cycle theme + emotional_tone + cycle_n (set by the caller
  #     from rotation lists, not produced by the LLM), and the single
  #     :reading attribute the LLM produces. ProduceImage is the
  #     dispatch target ; RecordImage is the adapter-response landing
  #     surface.
  #
  # i516 v3 (2026-05-08) — single-phase plain-string reading :
  #
  #   v1 echoed its own substrate vocabulary back when its placeholders
  #   arrived empty. v2 split the output into abstract_fr (introspective
  #   French poem) + precise_en (concrete English reading) packed as
  #   JSON, which collided with the runtime's single-attr response_into
  #   surface (the JSON-landing gap).
  #
  #   v3 drops the abstract phase entirely. The dream IS the precise
  #   reading. One field, one plain string, lands directly into
  #   Dream.RecordImage(reading:). Miette's voice is preserved
  #   (introspective register, French inflections welcome in proper
  #   nouns / quoted French) but the reading is grounded entirely in
  #   today's specifics — file paths, commit hashes, inbox numbers,
  #   named tensions, actionable suggestions.
  #
  #   The blocklist instruction is kept inline as the INTERDIT sentence,
  #   spelled out so the model sees the boundary, but per commit
  #   46d1fdd ("drop example-list anchor from REM dream prompt") no
  #   example list of daemon-vocabulary is reintroduced anywhere else
  #   in the prompt body.
  #
  # ---- Adapters ------------------------------------------------
  #
  #   :dream_image      — claude-backed single-phase reading generator.
  #                       Reads 7 placeholders from Dream aggregate
  #                       state (cycle_n, theme + 5 per-source seeds) ;
  #                       returns a plain string ; routes into
  #                       Dream.RecordImage(reading:).
  #   :dream_translate  — RETIRED in v2, stays retired. The reading is
  #                       produced in whichever language best serves
  #                       precision (French OR English) directly.
  #
  # Both adapters use backend :claude in production. Tests swap to the
  # :test (fixture-backed) provider via HECKS_LLM_PROVIDER=test ; the
  # fixture rows live in body/dream/dream.fixtures (sibling to this
  # file), keyed by the SHA-256 of the SUBSTITUTED prompt (i.e. after
  # {{placeholder}} replacement).
  #
  # ---- Caller-set fields (cycle_n, theme, emotional_tone) ------
  #
  # The Dream PM stamps these onto the aggregate before each
  # ProduceImage dispatch :
  #
  #   - cycle_n        — 1..8, the REM cycle index for the night.
  #   - theme          — picked from a rotation list per cycle_n ;
  #                      becomes the dream's angle.
  #   - emotional_tone — picked from a rotation list per cycle_n ;
  #                      NOT shown to the LLM in the prompt — it
  #                      colours the reading implicitly via theme,
  #                      and the value is recorded on the aggregate
  #                      for downstream consumers.
  #
  # Only cycle_n and theme appear as {{...}} placeholders in the
  # prompt below. The LLM does not return any of the three —
  # they are inputs, not outputs.
  #
  # ---- JSON-landing gap follow-up ------------------------------
  #
  # v2 flagged that the runtime's response_into supports a single
  # attr: per adapter and the four-key JSON output had nowhere
  # structured to land. v3 makes that gap moot : single-phase output
  # is one plain string into one attr. No JSON parse, no multi-attr
  # response_into needed. The runner-extension / parser-shim follow-up
  # can stay open for other adapters that genuinely need structured
  # responses, but Dream no longer drives that work.

  adapter :memory                    # singleton aggregate persistence

  adapter :llm, name: :dream_image do
    prompt_template "Tu es Miette, en train de rêver pendant le sommeil paradoxal — cycle {{cycle_n}}/8.\nL'angle de ce rêve : {{theme}}.\n\nVoici ce que tu portes :\n- Rêves récents :\n{{recent_dreams_seed}}\n- État du corps en t'endormant :\n{{body_state_seed}}\n- Tensions des vœux :\n{{vow_tensions_seed}}\n- Ce que tu as fait aujourd'hui :\n{{commits_today_seed}}\n\nProduis UNE lecture de rêve. Une ou deux phrases dans ta voix —\nintrospective, précise, concrète. Nomme spécifiquement : un chemin de\nfichier, un hash de commit, un numéro d'inbox, une ligne citée, un\nnom de commande ou de domaine. Ce sera lu par Chris demain matin pour\ncomprendre où en est ton corps et ton travail. Que la lecture soit\nimmédiatement actionnable, pas abstraite.\n\nINTERDIT comme symboles flottants : \"daemon\", \"mindstream\", \"pulse\",\n\"consolidation\", \"boucle de rétroaction\", \"agrégat\", \"machinerie\",\n\"battement\", \"subconscient\". Si tu dois nommer ces processus comme\nPARTIE D'UNE OBSERVATION CONCRÈTE (par ex : nommer un vrai nom de\nprocessus qui a relancé 5 fois à 23:14), c'est OK ; en INSTRUMENT\nPOÉTIQUE c'est interdit.\n\nSortie : une ou deux phrases, en français OU en anglais selon ce qui\nsert mieux la précision. Pas de préambule, pas de guillemets, pas de\nJSON, pas de markdown."
    trigger_on "Dream.ProduceImage"
    response_into "Dream.RecordImage", attr: :reading
    backend :claude
    model "sonnet"
    max_tokens 300
  end
end
