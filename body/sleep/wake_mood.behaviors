Hecks.behaviors "WakeMood" do
  vision "Behavioral tests for the WakeMood aggregate — mood + reason on wake."

  # ── WakeMood aggregate ──────────────────────────────────────────
  # (merged from sleep.behaviors during i112 cleanup)

  test "SetWakeMood sets mood + reason" do
    tests "SetWakeMood", on: "WakeMood"
    input  mood: "sample", reason: "sample"
    expect mood: "sample", reason: "sample"
  end
end
