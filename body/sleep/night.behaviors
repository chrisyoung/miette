Hecks.behaviors "Night" do
  vision "Behavioral tests for the Night aggregate — eight-cycle sleep arc."

  # ── Night aggregate ──────────────────────────────────────────
  # (merged from sleep.behaviors during i112 cleanup)

  test "StartNight runs" do
    tests "StartNight", on: "Night"
    expect cycles_completed: 0, phase: "starting"
  end

  # StartNight cascade test moved to dream_seed.behaviors — it exercises
  # the cross-aggregate SeedOnNightStart policy that triggers
  # DreamSeed.SeedFromPreviousDreams, which now lives in
  # aggregates/dream_seed.bluebook.

  test "DreamCycle1 runs" do
    tests "DreamCycle1", on: "Night"
    expect cycles_completed: 1, phase: "dreaming"
  end

  test "ConsolidateCycle1 runs" do
    tests "ConsolidateCycle1", on: "Night"
    expect phase: "consolidating"
  end

  test "DreamCycle2 runs" do
    tests "DreamCycle2", on: "Night"
    expect cycles_completed: 2, phase: "dreaming"
  end

  test "ConsolidateCycle2 runs" do
