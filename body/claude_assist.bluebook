Hecks.bluebook "ClaudeAssist", version: "2026.04.28.1" do
  vision "Toggle for LLM provider — selects which provider the body uses for dream generation, NREM narration, and other LLM cascades"
  category "body"

  # ============================================================
  # CLAUDE ASSIST — LLM provider toggle
  # ============================================================
  #
  # Selects which LLM the body's :llm adapters route to. Default
  # is 'claude' — uses the Anthropic API if ANTHROPIC_API_KEY is
  # set, otherwise falls back to the local `claude` CLI (Claude
  # Code). User can switch to 'local' to use ollama (configured
  # in the *.world file) instead, or 'off' to disable LLM calls
  # entirely.
  #
  # Toggle:
  #   hecks-life aggregates ClaudeAssist.UseClaudeProvider
  #   hecks-life aggregates ClaudeAssist.UseLocalProvider
  #   hecks-life aggregates ClaudeAssist.DisableLLM
  #
  # Lifted out of mindstream.bluebook in i112.

  aggregate "ClaudeAssist", "Selects which LLM the body uses. Default is 'claude' — uses the Anthropic API if ANTHROPIC_API_KEY is set, otherwise falls back to the local `claude` CLI (Claude Code). User can switch to 'local' to use ollama (configured in the *.world file) instead, or 'off' to disable LLM calls entirely." do
    identified_by :name
    attribute :name, String
    # value_object: Provider enum:claude|local|off
    attribute :provider, String

    command "UseClaudeProvider" do
      role "Creator"
      description "Use Claude (API if ANTHROPIC_API_KEY set; otherwise CLI). The default."
      then_set :provider, to: "claude"
      emits "ProviderSwitched"
    end

    command "UseLocalProvider" do
      role "Creator"
      description "Fall back to local ollama for LLM calls"
      then_set :provider, to: "local"
      emits "ProviderSwitched"
    end

    command "DisableLLM" do
      role "Creator"
      description "Disable LLM calls entirely"
      then_set :provider, to: "off"
      emits "LLMDisabled"
    end
  end
end
