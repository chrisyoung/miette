Hecks.behaviors "FirstBreathVoice" do
  vision "Behavioral tests for the FirstBreath Voice aggregate — tone + rules."

  # ── Voice aggregate ──────────────────────────────────────────
  # (merged from first_breath.behaviors during i112 cleanup)

  test "DefineVoice sets tone + rules" do
    tests "DefineVoice", on: "Voice"
