<%#
  dashboard.erb — Phase 1+2 of the Hecks Studio.
  Sections, top-down :
    1. Vital signs   (Consciousness)
    2. Running features grid (TickedFeature ; one card each)
    3. Recent events stub    (event_store ; populated phase 6)

  Every renderable element carries data-domain="..." so the
  ViewDomainTags validator can audit every concept against
  studio.bluebook. Buttons that dispatch a command carry the
  fully-qualified Aggregate.Command form.
%>

<section data-domain="Consciousness" class="card bg-base-200 shadow mb-6">
  <div class="card-body">
    <h2 class="card-title">Vital signs</h2>
    <div class="grid grid-cols-3 gap-4 mt-2">
      <div data-domain="Consciousness.state">
        <div class="text-xs uppercase opacity-60">State</div>
        <div class="text-3xl font-bold mt-1"><%= @vitals[:state] || "unknown" %></div>
      </div>
      <div data-domain="Consciousness.last_wake">
        <div class="text-xs uppercase opacity-60">Last wake</div>
        <div class="text-sm mt-1"><%= @vitals[:last_wake] || "—" %></div>
      </div>
      <div data-domain="Consciousness.last_dream">
        <div class="text-xs uppercase opacity-60">Last dream</div>
        <div class="text-sm mt-1 italic"><%= @vitals[:last_dream] || "—" %></div>
      </div>
    </div>
  </div>
</section>

<section class="mb-6">
  <h2 class="text-xl font-semibold mb-3">Running features</h2>

  <% if @features.empty? %>
    <div class="alert alert-warning" data-domain="TickedFeature">
      <span>No TickedFeature records yet. Cadences mount here once they boot.</span>
    </div>
  <% else %>
    <div class="grid grid-cols-3 gap-4">
      <% @features.each do |f| %>
        <div data-domain="TickedFeature" class="card bg-base-200 shadow feature-status-<%= f[:status] %>">
          <div class="card-body">
            <h3 class="card-title text-base" data-domain="TickedFeature.name"><%= f[:name] %></h3>
            <div class="text-xs opacity-70" data-domain="TickedFeature.status">
              status : <span class="badge badge-sm
                <%= f[:status] == "running" ? "badge-success" :
                    f[:status] == "late"    ? "badge-warning" :
                    f[:status] == "failed"  ? "badge-error"   : "badge-ghost" %>"><%= f[:status] %></span>
            </div>
            <div class="text-xs opacity-70" data-domain="TickedFeature.last_tick_at">
              last tick : <%= f[:last_tick_at] || "—" %>
            </div>
            <div class="text-xs opacity-70" data-domain="TickedFeature.expected_interval_ms">
              interval : <%= f[:expected_interval_ms] || "—" %> ms
            </div>
            <div class="card-actions justify-end mt-2">
              <button class="btn btn-sm" data-domain="TickedFeature.Tick" data-name="<%= f[:name] %>">
                Tick now
              </button>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<%= erb :_concerns_panel %>

<section data-domain="event_store" class="card bg-base-200 shadow">
  <div class="card-body">
    <h2 class="card-title">Recent events</h2>
    <p class="text-sm opacity-70">Event timeline lands in Phase 6 (SSE + event_store).</p>
  </div>
</section>
